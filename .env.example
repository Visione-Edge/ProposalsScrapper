# Copiá este archivo a .env y completá los valores

# Clave secreta para firmar sesiones (genera una random larga)
# Ejemplo: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Credenciales de acceso
SICOP_USERNAME=admin

# Contraseña hasheada con bcrypt (REQUERIDO)
# Genera el hash con: python3 -c "import bcrypt; print(bcrypt.hashpw(b'tu-password', bcrypt.gensalt()).decode())"
SICOP_PASSWORD_HASH=

# Cookies seguras (solo HTTPS). Poné "false" solo para desarrollo local sin HTTPS
SECURE_COOKIES=true

# Máximo de sesiones concurrentes permitidas (default: 5)
MAX_SESSIONS=5
