# Copiá este archivo a .env y completá los valores

# Clave secreta para firmar sesiones (generá una random larga)
SECRET_KEY=cambia-esto-por-algo-largo-y-random-en-produccion

# Credenciales de acceso al dashboard
SICOP_USERNAME=admin@visione-edge.com

# Opción 1: contraseña en texto plano (solo para desarrollo local)
SICOP_PASSWORD=tu-password-aqui

# Opción 2: contraseña hasheada con bcrypt (recomendado para producción)
# Generá el hash con: python3 -c "import bcrypt; print(bcrypt.hashpw(b'tu-password', bcrypt.gensalt(12)).decode())"
# SICOP_PASSWORD_HASH=$2b$12$...

# Contraseña SMTP para notificaciones por email
# El usuario y host se configuran en config.yaml
# Para Gmail: usá una App Password (https://myaccount.google.com/apppasswords)
SMTP_PASSWORD=tu-smtp-password-aqui
